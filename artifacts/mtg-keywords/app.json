{
  "expo": {
    "name": "MtG Master",
    "slug": "mtg-keywords",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mtg-keywords",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0d0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.greenorbital.masterofmtg"
    },
    "android": {
      "package": "de.greenorbital.masterofmtg",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f0d0a"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "usesCleartextTraffic": false
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "MtG Master",
      "shortName": "MoMtG",
      "description": "Magic: The Gathering Kartensuche, Keywords & Deck-Builder",
      "themeColor": "#c8a96e",
      "backgroundColor": "#0f0d0a",
      "display": "standalone",
      "orientation": "any",
      "lang": "de"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "./plugins/withAndroidPackagingOptions"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "57e3ee18-76ff-4782-85ff-b9dddb216a81"
      }
    },
    "owner": "greenorbital"
  }
}